DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=saferoute
DB_USER=saferoute_user
DB_PASSWORD=change-this-password

DJANGO_DEBUG=false
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
